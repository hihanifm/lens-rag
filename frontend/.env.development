# Dev (remote-friendly): keep API URL unset so the browser calls the Vite origin
# (e.g. http://<linux-ip>:37001) and Vite proxies /projects and /health to the API
# over the internal Docker network (see vite.config.js + docker-compose.yml).
VITE_API_URL=

# Optional: URL of the Lens RAGAS web portal. When set, the Evaluate page shows
# a direct link instead of the local evaluation instructions.
# Example: VITE_RAGAS_PORTAL_URL=http://ragas.internal.example.com
VITE_RAGAS_PORTAL_URL=
