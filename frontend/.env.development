# Dev only — API calls use relative paths, proxied by the Vite dev server to the backend.
# The proxy target is configured via VITE_API_PROXY_TARGET in vite.config.js.
# In Docker: docker-compose sets VITE_API_PROXY_TARGET=http://lens-rag-api:8000
# Locally (no Docker): proxy falls back to http://localhost:37000
VITE_API_URL=
