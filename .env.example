# Embedding provider: "ollama" (default, on-prem) or "openai" (testing)
EMBEDDING_PROVIDER=ollama

# Ollama settings (used when EMBEDDING_PROVIDER=ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# Startup auto-selects: qwen3-embedding:0.6b → bge-m3:latest → first available.
# Set here only if you need to pin a specific model.
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b
EMBEDDING_DIMS=1024

# pgvector HNSW max embedding width (raise to 4096 on pgvector 0.5.2+ if needed)
# PGVECTOR_MAX_INDEXED_DIMS=2000

# OpenAI settings (used when EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_EMBED_MODEL=text-embedding-3-small
# EMBEDDING_DIMS=1536  # override when switching to OpenAI

# Reranker — always Ollama (for Search; Compare runs default to disabled)
RERANKER_ENABLED=true
RERANKER_MODEL=bbjson/bge-reranker-base:latest

# LLM judge for Compare runs (disabled per run by default).
# Startup auto-selects: gemma4:e4b → llama3.1:8b → first available.
# Model preference is set in backend/config.py (LLM_JUDGE_MODEL_PREFERENCES).

# Docker base images for compose builds (defaults: AWS Public ECR mirrors of Docker Official Images).
# Many labs block Docker Hub; ECR often works. If both are blocked, use paths from your internal registry:
# PYTHON_IMAGE=registry.lab.example/library/python:3.11-slim
# NODE_IMAGE=registry.lab.example/library/node:20-bookworm-slim
# Restore Docker Hub explicitly:
# PYTHON_IMAGE=docker.io/library/python:3.11-slim
# NODE_IMAGE=docker.io/library/node:20-bookworm-slim
#
# Image pulls use the Docker *daemon* network settings. If compose HTTP_PROXY is not enough,
# configure systemd for docker.service (HTTP_PROXY/HTTPS_PROXY/NO_PROXY) so `docker build` can reach the registry.

# Lab forward proxy — passed into Dockerfile builds for pip/npm (not always used for docker pull)
# HTTP_PROXY=http://proxy.lab.internal:3128
# HTTPS_PROXY=http://proxy.lab.internal:3128
# NO_PROXY=localhost,127.0.0.1,host.docker.internal

# Lab CA certificate
# Drop your lab's CA cert (PEM, .crt extension) into the certs/ directory.
# Docker build will install it automatically. No changes needed here.
