# Embedding provider: "ollama" (default, on-prem) or "openai" (testing)
EMBEDDING_PROVIDER=ollama

# Ollama settings (used when EMBEDDING_PROVIDER=ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_EMBED_MODEL=bge-m3
EMBEDDING_DIMS=1024

# OpenAI settings (used when EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_EMBED_MODEL=text-embedding-3-small
# EMBEDDING_DIMS=1536  # override when switching to OpenAI

# Reranker — always Ollama
RERANKER_ENABLED=true
RERANKER_MODEL=bge-reranker-base

# Frontend dev image (default node:20-bookworm-slim). Set to an internal mirror if Docker Hub is blocked:
# NODE_IMAGE=registry.lab.example/nodejs:20-bookworm-slim

# Lab forward proxy (leave blank if not behind a proxy)
# HTTP_PROXY=http://proxy.lab.internal:3128
# HTTPS_PROXY=http://proxy.lab.internal:3128
# NO_PROXY=localhost,127.0.0.1,host.docker.internal

# Lab CA certificate
# Drop your lab's CA cert (PEM, .crt extension) into the certs/ directory.
# Docker build will install it automatically. No changes needed here.
